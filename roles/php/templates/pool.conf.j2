; {{ ansible_managed }}
[{{ php_fpm_pool }}]
user = www-data
group = www-data
listen = /run/php/php{{ php_version }}-fpm.sock
listen.owner = www-data
listen.group = www-data
listen.mode = 0660

pm = dynamic
pm.max_children = {{ php_fpm_max_children }}
pm.start_servers = {{ [ (php_fpm_max_children | int // 4), 2 ] | max }}
pm.min_spare_servers = {{ [ (php_fpm_max_children | int // 4), 1 ] | max }}
pm.max_spare_servers = {{ [ (php_fpm_max_children | int // 2), 3 ] | max }}
pm.max_requests = 500

php_admin_value[error_log] = /var/log/php{{ php_version }}-fpm.www.log
php_admin_flag[log_errors] = on

slowlog = /var/log/php{{ php_version }}-fpm.slow.log
request_slowlog_timeout = 10s
